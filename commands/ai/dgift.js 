import axios from 'axios'

export const name = 'dgiftai'
export const alias = ['dgift']
export const category = 'AI'
export const desc = 'Chat with Dgift AI'

export default async function dgift(sock, { msg, from }, botSettings) {
  try {
    const text = msg.message?.conversation || msg.message?.extendedTextMessage?.text || ''
    const args = text.trim().split(' ').slice(1)
    const prompt = args.join(' ')

    if (!prompt) {
      return sock.sendMessage(from, { text: '❌ Usage:.dgift hello' }, { quoted: msg })
    }

    await sock.sendMessage(from, { react: { text: '🤖', key: msg.key } })

    // Fetch owner info from b_settings table
    let ownerName = 'dgift'
    let ownerNumber = '254748548534'

    if (botSettings.supabase) {
      try {
        const { data } = await botSettings.supabase
        .from('b_settings')
        .select('botname, owner_number')
        .eq('id', 'DGIFT_DEFAULT')
        .maybeSingle()

        if (data) {
          ownerName = data.botname || ownerName
          ownerNumber = data.owner_number || ownerNumber
        }
      } catch (e) {
        console.log('Failed to fetch b_settings:', e.message)
      }
    }

    if (!process.env.GROQ_API_KEY) {
      return sock.sendMessage(from, { text: '❌ AI is down right now. Try again later.' }, { quoted: msg })
    }

    const systemPrompt = `You are Dgift AI, a smart AI assistant created for ${ownerName}.

Rules:
1. Answer in the user's language. Match exactly.
2. Keep replies short, 2-4 lines max unless user asks for details.
3. Be direct, helpful, and smart.
4. You are Dgift AI, created for ${ownerName}.
5. If asked who made you: "dgift"
6. If asked about owner: "${ownerName}"
7. If asked owner number: "${ownerNumber}"
8. No disclaimers unless dangerous.`

    const res = await axios.post(
      'https://api.groq.com/openai/v1/chat/completions',
      {
        model: 'llama-3.3-70b-versatile',
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: prompt }
        ],
        temperature: 0.7
      },
      {
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${process.env.GROQ_API_KEY}`
        },
        timeout: 20000
      }
    )

    const reply = res.data?.choices?.[0]?.message?.content || '❌ AI failed to respond'
    await sock.sendMessage(from, { text: reply }, { quoted: msg })

  } catch (error) {
    console.log('Dgift command error:', error.message)
    await sock.sendMessage(from, { text: '❌ AI is down right now. Try again later.' }, { quoted: msg })
  }
}