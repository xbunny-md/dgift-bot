// commands/download/TikTok.js
import axios from 'axios'

export const name = 'tiktok'
export const alias = ['tt', 'ttdl', 'tiktokdl']
export const category = 'Download'
export const desc = 'Download TikTok video/photo from link or replied message'

export default async function tiktok(sock, { msg, from, args, quoted }, botSettings) {
  try {
    const body = msg.message?.conversation || msg.message?.extendedTextMessage?.text || ''
    const cmdArgs = body.trim().split(' ').slice(1)

    let tiktokUrl = cmdArgs[0]

    // Angalia quoted message kama hakuna link
    if (!tiktokUrl && quoted) {
      const quotedText = quoted.message?.conversation ||
                         quoted.message?.extendedTextMessage?.text ||
                         quoted.message?.imageMessage?.caption ||
                         quoted.message?.videoMessage?.caption || ''
      const urlMatch = quotedText.match(/(https?:\/\/[^\s]+)/)
      if (urlMatch) tiktokUrl = urlMatch[0]
    }

    // Usage
    if (!tiktokUrl ||!tiktokUrl.includes('tiktok.com')) {
      await sock.sendMessage(from, { react: { text: '🎵', key: msg.key } })
      return await sock.sendMessage(from, {
        text: `╭─⌈ 🎵 *TikTok Downloader* ⌋
│ Status: Ready
│
│ Usage:
│ ${botSettings.prefix}tt https://tiktok.com/xxx
│ ${botSettings.prefix}tt [reply to TikTok link]
│
│ Note: Downloads video/photo without watermark
╰⊷ *${botSettings.botname}*`
      }, { quoted: msg })
    }

    await sock.sendMessage(from, { react: { text: '⏳', key: msg.key } })

    // Fix short URL
    if (tiktokUrl.includes('vm.tiktok.com') || tiktokUrl.includes('vt.tiktok.com')) {
      const res = await axios.get(tiktokUrl, {
        maxRedirects: 5,
        headers: { 'User-Agent': 'Mozilla/5.0' }
      })
      tiktokUrl = res.request.res.responseUrl
    }

    // Fetch HTML
    const { data: html } = await axios.get(tiktokUrl, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (iPhone; CPU iPhone OS 16_6 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.6 Mobile/15E148 Safari/604.1',
        'Accept-Language': 'en-US,en;q=0.9'
      },
      timeout: 20000
    })

    // Extract JSON data
    const jsonMatch = html.match(/<script id="__UNIVERSAL_DATA_FOR_REHYDRATION__" type="application\/json">(.*?)<\/script>/)
    if (!jsonMatch) {
      await sock.sendMessage(from, { react: { text: '❌', key: msg.key } })
      return await sock.sendMessage(from, { text: '> Failed to extract video data. Video may be private.' }, { quoted: msg })
    }

    const json = JSON.parse(jsonMatch[1])
    const videoData = json.__DEFAULT_SCOPE__?.['webapp.video-detail']?.itemInfo?.itemStruct

    if (!videoData) {
      await sock.sendMessage(from, { react: { text: '❌', key: msg.key } })
      return await sock.sendMessage(from, { text: '> No media found. Video may be private or deleted.' }, { quoted: msg })
    }

    const author = videoData.author?.nickname || videoData.author?.uniqueId || 'Unknown'
    const title = videoData.desc || 'TikTok Download'

    await sock.sendMessage(from, { react: { text: '✅', key: msg.key } })

    // Photo post
    if (videoData.imagePost && videoData.imagePost.images) {
      const images = videoData.imagePost.images
      for (let i = 0; i < images.length; i++) {
        const imgUrl = images[i].imageURL?.urlList?.[0]
        if (!imgUrl) continue

        await sock.sendMessage(from, {
          image: { url: imgUrl },
          caption: i === 0? `╭─⌈ 📸 *TikTok Photo* ⌋
│ Author: ${author}
│ Title: ${title}
╰⊷ *${botSettings.botname}*` : '',
          quoted: i === 0? msg : undefined
        })
        await new Promise(r => setTimeout(r, 1200))
      }
      return
    }

    // Video post
    const videoUrl = videoData.video?.playAddr?.[0] || videoData.video?.downloadAddr?.[0]
    if (!videoUrl) {
      await sock.sendMessage(from, { react: { text: '❌', key: msg.key } })
      return await sock.sendMessage(from, { text: '> Video URL not found.' }, { quoted: msg })
    }

    await sock.sendMessage(from, {
      video: { url: videoUrl },
      caption: `╭─⌈ 🎵 *TikTok Download* ⌋
│ Author: ${author}
│ Title: ${title}
│ Type: Video
╰⊷ *${botSettings.botname}*`,
      quoted: msg
    })

  } catch (err) {
    console.error(`[TIKTOK CMD ERROR]`, err.message)
    await sock.sendMessage(from, { react: { text: '❌', key: msg.key } })
    await sock.sendMessage(from, { text: '> Failed to download. Video may be private or TikTok blocked the request.' }, { quoted: msg })
  }
}