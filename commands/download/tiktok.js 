// commands/download/tiktok.js
import axios from 'axios'

export const name = 'tiktok'
export const alias = ['tt', 'ttdl', 'tiktokdl']
export const category = 'Download'
export const desc = 'Download TikTok video/photo from link or replied message'

function extractUrl(text) {
  if (!text) return null
  const match = text.match(/(https?:\/\/[^\s]+)/)
  return match? match[0] : null
}

export default async function tiktok(sock, { msg, from, args }, botSettings) {
  console.log('[TIKTOK] Command triggered')

  try {
    // Get full message text
    const body = msg.message?.conversation ||
                 msg.message?.extendedTextMessage?.text ||
                 ''

    console.log('[TIKTOK] Body:', body)

    // Get URL from args or quoted message
    let tiktokUrl = args[0]

    if (!tiktokUrl) {
      const quoted = msg.message?.extendedTextMessage?.contextInfo?.quotedMessage
      const quotedText = quoted?.conversation ||
                         quoted?.extendedTextMessage?.text ||
                         quoted?.imageMessage?.caption ||
                         quoted?.videoMessage?.caption || ''

      console.log('[TIKTOK] Quoted text:', quotedText)
      tiktokUrl = extractUrl(quotedText)
    }

    console.log('[TIKTOK] URL found:', tiktokUrl)

    // Usage
    if (!tiktokUrl ||!tiktokUrl.includes('tiktok.com')) {
      await sock.sendMessage(from, { react: { text: '🎵', key: msg.key } })
      return await sock.sendMessage(from, {
        text: `╭─⌈ 🎵 *TikTok Downloader* ⌋
│ Status: Ready
│
│ Usage:
│ ${botSettings.prefix}tt https://tiktok.com/xxx
│ ${botSettings.prefix}tt [reply to TikTok link]
│
│ Note: Downloads video/photo without watermark
╰⊷ *${botSettings.botname}*`
      }, { quoted: msg })
    }

    await sock.sendMessage(from, { react: { text: '⏳', key: msg.key } })

    // Follow redirects for short URLs
    if (tiktokUrl.includes('vm.tiktok.com') || tiktokUrl.includes('vt.tiktok.com')) {
      console.log('[TIKTOK] Resolving short URL...')
      try {
        const res = await axios.get(tiktokUrl, {
          maxRedirects: 5,
          headers: { 'User-Agent': 'Mozilla/5.0' },
          timeout: 15000
        })
        tiktokUrl = res.request.res.responseUrl
        console.log('[TIKTOK] Resolved URL:', tiktokUrl)
      } catch (e) {
        console.log('[TIKTOK] Short URL resolve failed:', e.message)
      }
    }

    // Fetch page HTML
    console.log('[TIKTOK] Fetching HTML...')
    const { data: html } = await axios.get(tiktokUrl, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (iPhone; CPU iPhone OS 16_6 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.6 Mobile/15E148 Safari/604.1',
        'Accept-Language': 'en-US,en;q=0.9'
      },
      timeout: 20000
    })

    console.log('[TIKTOK] HTML length:', html.length)

    // Extract JSON data
    const jsonMatch = html.match(/<script id="__UNIVERSAL_DATA_FOR_REHYDRATION__" type="application\/json">(.*?)<\/script>/)
    if (!jsonMatch) {
      console.log('[TIKTOK] JSON not found in HTML')
      await sock.sendMessage(from, { react: { text: '❌', key: msg.key } })
      return await sock.sendMessage(from, { text: '> Failed to extract video data. Video may be private or region locked.' }, { quoted: msg })
    }

    console.log('[TIKTOK] JSON found, parsing...')
    const json = JSON.parse(jsonMatch[1])
    const videoData = json.__DEFAULT_SCOPE__?.['webapp.video-detail']?.itemInfo?.itemStruct

    if (!videoData) {
      console.log('[TIKTOK] videoData is null')
      await sock.sendMessage(from, { react: { text: '❌', key: msg.key } })
      return await sock.sendMessage(from, { text: '> No media found. Video may be private or deleted.' }, { quoted: msg })
    }

    const author = videoData.author?.nickname || videoData.author?.uniqueId || 'Unknown'
    const title = videoData.desc || 'TikTok Download'

    console.log('[TIKTOK] Author:', author, 'Title:', title)

    await sock.sendMessage(from, { react: { text: '✅', key: msg.key } })

    // Photo post
    if (videoData.imagePost && videoData.imagePost.images?.length > 0) {
      console.log('[TIKTOK] Detected photo post with', videoData.imagePost.images.length, 'images')
      const images = videoData.imagePost.images

      for (let i = 0; i < images.length; i++) {
        const imgUrl = images[i].imageURL?.urlList?.[0]
        if (!imgUrl) continue

        await sock.sendMessage(from, {
          image: { url: imgUrl },
          caption: i === 0? `╭─⌈ 📸 *TikTok Photo* ⌋
│ Author: ${author}
│ Title: ${title}
╰⊷ *${botSettings.botname}*` : ''
        })
        await new Promise(r => setTimeout(r, 1200))
      }
      console.log('[TIKTOK] Photo send complete')
      return
    }

    // Video post
    const videoUrl = videoData.video?.playAddr?.[0] || videoData.video?.downloadAddr?.[0]
    if (!videoUrl) {
      console.log('[TIKTOK] No video URL found')
      await sock.sendMessage(from, { react: { text: '❌', key: msg.key } })
      return await sock.sendMessage(from, { text: '> Video URL not found. Try again later.' }, { quoted: msg })
    }

    console.log('[TIKTOK] Sending video:', videoUrl.slice(0, 50) + '...')
    await sock.sendMessage(from, {
      video: { url: videoUrl },
      caption: `╭─⌈ 🎵 *TikTok Download* ⌋
│ Author: ${author}
│ Title: ${title}
│ Type: Video
╰⊷ *${botSettings.botname}*`,
      quoted: msg
    })

    console.log('[TIKTOK] Success')

  } catch (err) {
    console.error('[TIKTOK CMD ERROR]', err)
    await sock.sendMessage(from, { react: { text: '❌', key: msg.key } }).catch(() => {})
    await sock.sendMessage(from, {
      text: `> Download failed: ${err.message}\n> Video may be private, deleted, or TikTok blocked the request.`
    }, { quoted: msg }).catch(() => {})
  }
}